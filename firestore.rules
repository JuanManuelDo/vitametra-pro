rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny: Block all access by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Colección de Usuarios - Estricto Aislamiento
    match /users/{userId} {
      allow read, create: if request.auth != null && request.auth.uid == userId;
      
      // Bloqueo: Nadie puede cambiar su propio rol o plan manualmente
      allow update: if request.auth != null && request.auth.uid == userId 
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'subscription_tier']));
    }

    // Colección de Auditoría (Crítica para Seguridad)
    match /logs_auditoria/{logId} {
      // Regla de Oro: Solo creación. Prohibido leer, borrar o editar (Append-only)
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // Historial Médico (Datos Sensibles de Ingesta y Glucosa)
    // Se delega la validación estricta de estructura y tipos a la Cloud Function (Zod)
    // Estas reglas actúan como la última línea de defensa mutua.
    match /users/{userId}/history/{monthId}/logs/{entryId} {
      // Granular access constraint: you can only read/delete your own logs
      allow read, delete: if request.auth != null && request.auth.uid == userId;
      
      // La creación y actualización se realizará vía Cloud Functions usando Admin SDK
      // por lo que no es estrictamente necesario habilitarlas aquí para el cliente web.
      // Sin embargo, si la web sigue escribiendo en algunas partes, mantenemos el aislamiento.
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }
    
    // Bandeja Temporal de Reportes
    match /users/{userId}/pending_reports/{fileId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Historico de Laboratorio o Proyecciones de A1c
    match /hba1c_logs/{logId} {
        allow read, create, update, delete: if request.auth != null && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
    }

    // Instituciones B2B
    match /institutions/{instId} {
      allow read: if request.auth != null;
      allow write: if false; // Solo por Cloud Functions Admin o Panel
    }
  }
}
